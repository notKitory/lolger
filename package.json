{
	"name": "lolger",
	"version": "1.4.0",
	"description": "Yet another beautiful (useless) logger",
	"keywords": [
		"logger",
		"logging",
		"console",
		"chalk",
		"commonjs",
		"cjs",
		"typescript",
		"esm"
	],
	"license": "Apache-2.0",
	"author": "Dmitry Koteykin",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/notKitory/lolger.git"
	},
	"bugs": {
		"url": "https://github.com/notKitory/lolger/issues"
	},
	"homepage": "https://github.com/notKitory/lolger#readme",
	"type": "module",
	"main": "./dist/cjs/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/cjs/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"clean": "node ./scripts/clean.mjs",
		"build:esm": "tsc -p tsconfig.json",
		"build:cjs": "tsc -p tsconfig.cjs.json",
		"build:cjs:package": "node ./scripts/write-cjs-package.mjs",
		"build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:cjs:package",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "node ./scripts/lint.mjs",
		"test": "npm run build && node --test ./test/index.test.js",
		"deno:smoke": "deno run --no-check --allow-read --allow-write --allow-env --node-modules-dir=manual ./test/deno-smoke.ts",
		"verify": "npm run lint && npm run typecheck && npm test",
		"prepublishOnly": "npm run verify"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"json-stringify-safe": "^5.0.1"
	},
	"devDependencies": {
		"@types/json-stringify-safe": "^5.0.3",
		"typescript": "^6.0.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
